# Default (dev + prod): /api
# - Dev: Vite proxy → http://127.0.0.1:8787
# - Prod: Cloudflare Worker proxy → https://cursorunofficialnews.fly.dev
# VITE_API_BASE=/api

# Local direct API (skip Vite proxy):
# VITE_API_BASE=http://127.0.0.1:8787

# Optional prod override — direct Fly URL instead of /api worker proxy:
# VITE_API_BASE=https://cursorunofficialnews.fly.dev
# See docs/CLOUDFLARE-DEPLOY.md

# Local dev only — ignored in production builds
# Only needed when mobile/server/.env sets INGEST_SECRET locally
# VITE_INGEST_SECRET=your-secret-here

# --- Monetization (optional) ---

# Google AdSense publisher ID (ca-pub-xxxxxxxxxxxxxxxx)
VITE_ADSENSE_CLIENT_ID=ca-pub-5184491334740169

# Display ad slot — REQUIRED for in-app ad placements (MonetizationSection + in-feed AdSlot).
# AdSense → Ads → By ad unit → Display ads → create unit → copy the ad slot ID (numeric).
# Also enable Auto ads in AdSense if you want Google to place extra units site-wide.
VITE_ADSENSE_SLOT_ID=

# Legacy alias (same value as VITE_ADSENSE_SLOT_ID)
# VITE_ADSENSE_SLOT=

# Buy Me a Coffee username (page slug) — optional; prod build defaults to casiezeq if unset
# VITE_BMC_USERNAME=casiezeq
# Go-live: docs/BMC-GO-LIVE.md (webhook secret goes on Fly, not here)

# Optional per-tier checkout URLs ($1–$5 monthly) — override default membership page link
# VITE_BMC_TIER_URL_1=
# VITE_BMC_TIER_URL_2=
# VITE_BMC_TIER_URL_3=
# VITE_BMC_TIER_URL_4=
# VITE_BMC_TIER_URL_5=

# Dev only: hide ads for all visitors without BMC webhook
# VITE_BMC_DEV_ADFREE=true

# Monetization (optional — components hidden when unset)
# VITE_BMAC_URL=https://buymeacoffee.com/yourusername
