# Local dev — defaults to Vite proxy /api → http://127.0.0.1:8787 (see vite.config.js)
# VITE_API_BASE=/api

# Local direct API (skip proxy):
# VITE_API_BASE=http://127.0.0.1:8787

# Production (Cloudflare Pages) — set in Pages env vars, NOT in a committed .env:
# VITE_API_BASE=https://cursorunofficialnews.fly.dev
# See docs/CLOUDFLARE-DEPLOY.md

# Only needed when mobile/server/.env sets INGEST_SECRET locally
# VITE_INGEST_SECRET=your-secret-here
