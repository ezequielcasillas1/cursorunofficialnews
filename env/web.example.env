# Default (dev + prod): /api
# - Dev: Vite proxy → http://127.0.0.1:8787
# - Prod: Cloudflare Worker proxy → https://news-api.cursorunofficial.news
# VITE_API_BASE=/api

# Local direct API (skip Vite proxy — must include /api prefix):
# VITE_API_BASE=http://127.0.0.1:8787/api

# Optional prod override — direct Fly URL instead of /api worker proxy:
# VITE_API_BASE=https://news-api.cursorunofficial.news
# See docs/CLOUDFLARE-DEPLOY.md

# Local dev only — ignored in production builds
# Only needed when mobile/server/.env sets INGEST_SECRET locally
# VITE_INGEST_SECRET=your-secret-here

# --- Monetization (Stripe membership — checkout sessions are created server-side) ---

# Google AdSense publisher ID (ca-pub-xxxxxxxxxxxxxxxx)
VITE_ADSENSE_CLIENT_ID=ca-pub-5184491334740169

# Display ad slot — REQUIRED for in-app ad placements (MonetizationSection + in-feed AdSlot).
# AdSense → Ads → By ad unit → Display ads → create unit → copy the ad slot ID (numeric).
# Also enable Auto ads in AdSense if you want Google to place extra units site-wide.
VITE_ADSENSE_SLOT_ID=

# Legacy alias (same value as VITE_ADSENSE_SLOT_ID)
# VITE_ADSENSE_SLOT=

# No VITE_STRIPE_* vars are needed — the $1-$5/mo Checkout Session is created by
# the Worker (see env/server.example.env) and the browser is redirected to the
# returned Stripe-hosted URL. Go-live: docs/STRIPE-GO-LIVE.md

# Dev only: newsletter + membership local test (no Stripe checkout)
# VITE_MEMBERSHIP_DEV_ACTIVE=true
# VITE_MEMBERSHIP_DEV_EMAIL=you@example.com
# Pair with env/server/.env: DEV_BYPASS_MEMBERSHIP, MEMBERSHIP_DEV_EMAILS, N8N_NEWSLETTER_WEBHOOK_URL
