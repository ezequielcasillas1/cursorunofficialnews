# Pipedream Connect — REST API OAuth (developer / MCP tooling)
# Edit C:\Dev\CursorAINews\api\.env — DO NOT commit it or paste secrets in chat.

# REST API OAuth client (client_credentials grant)
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=

# Connect project (from pd init connect or Pipedream dashboard)
PIPEDREAM_PROJECT_ID=proj_mJsxa0P

# development | production
PIPEDREAM_PROJECT_ENVIRONMENT=development

# Optional — org slug from dashboard URL
# PIPEDREAM_ORG_ID=o_pNI7KjZ
