# Copy to .env and restart Expo after changes.
#
# Physical Android (pick one):
#   USB + adb reverse tcp:8787 tcp:8787  → default http://127.0.0.1:8787 works
#   Wi‑Fi (no adb)                       → set your PC LAN IP:
# EXPO_PUBLIC_API_BASE=http://192.168.1.98:8787
#
# Android emulator: default http://10.0.2.2:8787 (no .env needed)
