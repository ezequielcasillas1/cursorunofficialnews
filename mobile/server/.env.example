# Optional scrape fallback (Firecrawl-compatible POST endpoint)

# When unset, scrape sources are skipped gracefully.

SCRAPE_API_URL=https://api.firecrawl.dev/v1/scrape

SCRAPE_API_KEY=



# Optional X (Twitter) API v2 — enables twitter-api ingest sources when set

# Without this, X posts use the RSS bridge feed in registry (nitter.net)

TWITTER_BEARER_TOKEN=



PORT=8787



# Push notifications (Expo) — set false to disable

PUSH_NOTIFICATIONS=true



# Email digest (Resend) — set false to disable; omit RESEND_API_KEY to skip gracefully

EMAIL_NOTIFICATIONS=true

RESEND_API_KEY=

# Example uses Resend sandbox sender — verify your domain in the Resend dashboard
# and replace with e.g. Unofficial Cursor News <news@yourdomain.com> before production

RESEND_FROM_EMAIL=Unofficial Cursor News <onboarding@resend.dev>



# Public site URL for signup confirmation links in verification emails
# Local web testing: PUBLIC_WEB_BASE=http://127.0.0.1:5173
# Production: PUBLIC_WEB_BASE=https://cursorunofficial.news

# Digest confirmation links expire after this many minutes (default 1440 = 24h)
# EMAIL_VERIFY_TTL_MINUTES=1440

# Public API base URL — used for signed email unsubscribe links

PUBLIC_API_BASE=http://127.0.0.1:8787

# n8n newsletter automation (optional)
# When set, ingest triggers this webhook with new headline payloads.
# N8N_NEWSLETTER_WEBHOOK_URL=https://your-n8n.example.com/webhook/cursor-newsletter
# N8N_NEWSLETTER_WEBHOOK_SECRET=optional-shared-secret
# N8N_NEWSLETTER_MODE=parallel
# parallel = server Resend + n8n webhook; primary = n8n only; off = server only

# Optional explicit browser origins allowed to call this API (comma-separated)
# CORS_ALLOWED_ORIGINS=https://cursorunofficial.news,http://127.0.0.1:5173



# Ingest protection — required when NODE_ENV=production

# Pass via X-API-Secret header or Authorization: Bearer <secret>

INGEST_SECRET=



# Optional device register protection (leave unset for public registration)

REGISTER_SECRET=



# Scheduled ingest — in-process node-cron when true (optional locally; default off for dev)
# Alternative: keep false and use scripts/trigger-ingest.js with system cron

INGEST_CRON_ENABLED=false

INGEST_CRON_SCHEDULE=*/30 * * * *



# --- Buy Me a Coffee membership (optional) ---

# Webhook secret from https://www.buymeacoffee.com/webhooks
# BMC_WEBHOOK_SECRET=

# Public site URL for ad-free activation links in BMC welcome emails
# PUBLIC_WEB_BASE=https://cursorunofficial.news

# One-time supporter claim links expire after this many minutes
# MEMBERSHIP_CLAIM_TTL_MINUTES=30

# Dev: comma-separated emails treated as active members (no webhook needed)
# BMC_DEV_ADFREE_EMAILS=you@example.com

# Full go-live checklist: docs/BMC-GO-LIVE.md



# --- LM Studio (optional local LLM, 8B–13B) ---

# OpenAI-compatible API — start server in LM Studio (default port 1234)

# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Model id from LM Studio after loading a model (required for /v1/llm/*)

# LM_STUDIO_MODEL=

# LM_STUDIO_API_KEY=lm-studio

# LM_STUDIO_TIMEOUT_MS=120000

# Setup + test: docs/LM-STUDIO.md

# --- Cursor API (newsletter AI HTML via Composer 2.5) ---
# User or service-account key from Cursor Dashboard → Integrations / API Keys
# CURSOR_API_KEY=
# CURSOR_API_BASE_URL=https://api.cursor.com
# CURSOR_NEWSLETTER_MODEL=composer-2.5
# CURSOR_NEWSLETTER_FAST=true
# CURSOR_NEWSLETTER_TIMEOUT_MS=180000
# CURSOR_NEWSLETTER_POLL_MS=2000


