# Optional scrape fallback (Firecrawl-compatible POST endpoint)

# When unset, scrape sources are skipped gracefully.

SCRAPE_API_URL=https://api.firecrawl.dev/v1/scrape

SCRAPE_API_KEY=



PORT=8787



# Push notifications (Expo) — set false to disable

PUSH_NOTIFICATIONS=true



# Email digest (Resend) — set false to disable; omit RESEND_API_KEY to skip gracefully

EMAIL_NOTIFICATIONS=true

RESEND_API_KEY=

# Example uses Resend sandbox sender — verify your domain in the Resend dashboard
# and replace with e.g. Unofficial Cursor News <news@yourdomain.com> before production

RESEND_FROM_EMAIL=Unofficial Cursor News <onboarding@resend.dev>



# Public API base URL — used for signed email unsubscribe links

PUBLIC_API_BASE=http://127.0.0.1:8787



# Ingest protection — required when NODE_ENV=production

# Pass via X-API-Secret header or Authorization: Bearer <secret>

INGEST_SECRET=



# Optional device register protection (leave unset for public registration)

REGISTER_SECRET=



# Scheduled ingest — in-process node-cron when true (optional locally; default off for dev)
# Alternative: keep false and use scripts/trigger-ingest.js with system cron

INGEST_CRON_ENABLED=false

INGEST_CRON_SCHEDULE=*/30 * * * *



# --- Buy Me a Coffee membership (optional) ---

# Webhook secret from https://www.buymeacoffee.com/webhooks
# BMC_WEBHOOK_SECRET=

# Public site URL for ad-free activation links in BMC welcome emails
# PUBLIC_WEB_BASE=https://cursorunofficial.news

# Dev: comma-separated emails treated as active members (no webhook needed)
# BMC_DEV_ADFREE_EMAILS=you@example.com


